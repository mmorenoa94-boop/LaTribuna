generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// USUARIOS

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String    @default("Hincha")
  image         String?
  passwordHash  String?
  city          String?
  phone         String?
  bio           String?
  favoriteTeam  String?
  birthDate     DateTime?
  gender        Gender?
  role          UserRole  @default(HINCHA)
  level         Int       @default(1)
  xp            Int       @default(0)
  streak        Int       @default(0)
  streakLastAt  DateTime?
  profilePct    Int       @default(15)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  business          Business?
  wallet            Wallet?
  leagueMemberships LeagueMember[]
  predictions       Prediction[]
  answers           Answer[]
  notifications     Notification[]
  interests         UserInterest[]
  checkins          Checkin[]
  redemptions       Redemption[]
  pushSubscriptions PushSubscription[]
  achievements      UserAchievement[]
  poolEntries       PoolEntry[]
}

enum UserRole {
  HINCHA
  NEGOCIO
  SUPER_ADMIN
}

enum Gender {
  MASCULINO
  FEMENINO
  OTRO
  PREFIERO_NO_DECIR
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Business {
  id            String       @id @default(cuid())
  userId        String       @unique
  user          User         @relation(fields: [userId], references: [id])
  name          String
  type          BusinessType
  logoUrl       String?
  address       String?
  lat           Float?
  lng           Float?
  checkinRadius Int          @default(150)
  maxCapacity   Int?
  city          String?
  phone         String?
  isPremium     Boolean      @default(false)
  premiumUntil  DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  leagues    League[]
  promotions Promotion[]
  rewards    Reward[]
  battles    BattleParticipant[]
  checkins   Checkin[]
}

enum BusinessType {
  BAR
  RESTAURANT
  CLUB_CASINO
  OTHER
}

// LIGAS

model League {
  id                   String       @id @default(cuid())
  name                 String
  description          String?
  creatorId            String
  businessId           String?
  business             Business?    @relation(fields: [businessId], references: [id])
  type                 LeagueType   @default(PRIVATE)
  matchMode            MatchMode    @default(PER_MATCH)
  allowRemote          Boolean      @default(false)
  requireApproval      Boolean      @default(false)
  allowMemberInvites   Boolean      @default(true)
  presentialMultiplier Float        @default(1.0)
  maxMembers           Int          @default(50)
  inviteCode           String       @unique
  seasonEndDate        DateTime?
  minConsumption       Boolean      @default(false)
  minConsumptionAmount Int?
  verificationType     VerifType?
  bannerUrl            String?
  themeColor           String?      @default("#00E676")
  scoringMode          ScoringMode  @default(FIXED)
  status               LeagueStatus @default(ACTIVE)
  createdAt            DateTime     @default(now())

  members   LeagueMember[]
  matches   LeagueMatch[]
  questions LeagueQuestion[]
  prizes    LeaguePrize[]
  powerups  PowerUp[]
}

enum LeagueType {
  PRIVATE
  INVITE_ONLY
  PUBLIC
  BUSINESS
}

enum MatchMode {
  PER_MATCH
  SEASON
  HYBRID
}

enum ScoringMode {
  FIXED // Cada respuesta correcta da los puntos fijos de la pregunta
  POOL // Los puntos se reparten entre los que aciertan
}

enum VerifType {
  QR
  STAFF_CODE
  RECEIPT
}

enum LeagueStatus {
  ACTIVE
  FINISHED
  CANCELLED
}

model LeagueMember {
  id                  String       @id @default(cuid())
  leagueId            String
  league              League       @relation(fields: [leagueId], references: [id])
  userId              String
  user                User         @relation(fields: [userId], references: [id])
  totalPoints         Int          @default(0)
  consumptionVerified Boolean      @default(false)
  status              MemberStatus @default(APPROVED)
  joinedAt            DateTime     @default(now())

  @@unique([leagueId, userId])
}

enum MemberStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaguePrize {
  id          String @id @default(cuid())
  leagueId    String
  league      League @relation(fields: [leagueId], references: [id])
  position    Int
  description String
  pointsValue Int    @default(0)
}

// PARTIDOS

model Match {
  id           String      @id @default(cuid())
  externalId   String      @unique
  homeTeam     String
  awayTeam     String
  homeLogo     String?
  awayLogo     String?
  competition  String
  venue        String?
  kickoffAt    DateTime
  status       MatchStatus @default(SCHEDULED)
  homeScore    Int?
  awayScore    Int?
  minutePlayed Int?
  rawData      Json?
  updatedAt    DateTime    @updatedAt

  leagueMatches LeagueMatch[]
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FINISHED
  CANCELLED
}

model LeagueMatch {
  id       String @id @default(cuid())
  leagueId String
  league   League @relation(fields: [leagueId], references: [id])
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id])

  @@unique([leagueId, matchId])
}

// PREGUNTAS Y RESPUESTAS

model LeagueQuestion {
  id            String         @id @default(cuid())
  leagueId      String
  league        League         @relation(fields: [leagueId], references: [id])
  matchId       String
  text          String
  type          QuestionType
  options       Json
  correctAnswer String?
  pointsValue   Int            @default(20)
  orderIndex    Int            @default(0)
  timing        QuestionTiming @default(PRE_MATCH)
  status        QuestionStatus @default(PENDING)
  openAt        DateTime?
  closedAt      DateTime?
  resolvedAt    DateTime?

  totalPot     Int?
  winnersCount Int?

  predictions Prediction[]
  answers     Answer[]
}

enum QuestionType {
  WINNER
  SCORE
  SCORER
  YES_NO
  RANGE
  CUSTOM
}

enum QuestionTiming {
  PRE_MATCH
  LIVE
}

enum QuestionStatus {
  PENDING
  OPEN
  CLOSED
  RESOLVED
}

model Prediction {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  questionId   String
  question     LeagueQuestion @relation(fields: [questionId], references: [id])
  answer       String
  isCorrect    Boolean?
  pointsEarned Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([userId, questionId])
}

model Answer {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  questionId   String
  question     LeagueQuestion @relation(fields: [questionId], references: [id])
  answer       String
  answeredAt   DateTime       @default(now())
  isCorrect    Boolean?
  pointsEarned Int            @default(0)

  @@unique([userId, questionId])
}

// WALLET

model Wallet {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String          @id @default(cuid())
  walletId    String
  wallet      Wallet          @relation(fields: [walletId], references: [id])
  type        TransactionType
  amount      Int
  description String
  referenceId String?
  createdAt   DateTime        @default(now())
}

enum TransactionType {
  MATCH_WIN
  PREDICTION_WIN
  PROFILE_BONUS
  POWER_UP_WIN
  REDEMPTION
  EXPIRY
  ADMIN_ADJUSTMENT
}

// PREMIOS

model Reward {
  id          String       @id @default(cuid())
  businessId  String
  business    Business     @relation(fields: [businessId], references: [id])
  name        String
  description String?
  imageUrl    String?
  pointsCost  Int
  stock       Int?
  status      RewardStatus @default(ACTIVE)
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())

  redemptions Redemption[]
}

enum RewardStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

model Redemption {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  rewardId   String
  reward     Reward           @relation(fields: [rewardId], references: [id])
  code       String           @unique
  status     RedemptionStatus @default(PENDING)
  redeemedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime         @default(now())
}

enum RedemptionStatus {
  PENDING
  REDEEMED
  EXPIRED
}

// POWER-UPS

model PowerUp {
  id           String    @id @default(cuid())
  leagueId     String
  league       League    @relation(fields: [leagueId], references: [id])
  matchId      String
  question     String
  options      Json
  rewardText   String
  durationSecs Int       @default(30)
  trigger      PUTrigger @default(MANUAL)
  triggerMin   Int?
  status       PUStatus  @default(CONFIGURED)
  firedAt      DateTime?
  createdAt    DateTime  @default(now())
}

enum PUTrigger {
  MANUAL
  GOAL
  HALFTIME
  MINUTE
}

enum PUStatus {
  CONFIGURED
  FIRED
  EXPIRED
}

// PROMOCIONES

model Promotion {
  id          String       @id @default(cuid())
  businessId  String
  business    Business     @relation(fields: [businessId], references: [id])
  title       String?      @db.VarChar(60)
  message     String       @db.VarChar(280)
  imageUrl    String?
  segment     PromoSegment @default(ALL_IN_VENUE)
  channels    Json
  timing      PromoTiming  @default(IMMEDIATE)
  scheduledAt DateTime?
  sentAt      DateTime?
  status      PromoStatus  @default(DRAFT)
  reach       Int          @default(0)
  createdAt   DateTime     @default(now())
}

enum PromoSegment {
  ALL_IN_VENUE
  LEAGUE_PLAYERS
  VERIFIED_CONSUMERS
  RECURRING
}

enum PromoTiming {
  IMMEDIATE
  HALFTIME
  SCHEDULED
}

enum PromoStatus {
  DRAFT
  SENT
  SCHEDULED
  EXPIRED
}

// BATALLA DE NEGOCIOS

model Battle {
  id          String       @id @default(cuid())
  name        String
  zone        String
  organizer   String
  matchIds    Json
  prizeDesc   String?
  prizeAmount Int?
  startDate   DateTime
  endDate     DateTime
  status      BattleStatus @default(UPCOMING)
  createdAt   DateTime     @default(now())

  participants BattleParticipant[]
}

enum BattleStatus {
  UPCOMING
  ACTIVE
  FINISHED
}

model BattleParticipant {
  id         String   @id @default(cuid())
  battleId   String
  battle     Battle   @relation(fields: [battleId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  score      Int      @default(0)
  rank       Int?
  joinedAt   DateTime @default(now())

  @@unique([battleId, businessId])
}

// PUSH / NOTIFICACIONES

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

// CHECK-INS

model Checkin {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  businessId String
  business   Business  @relation(fields: [businessId], references: [id])
  lat        Float
  lng        Float
  checkedAt  DateTime  @default(now())
  checkedOut DateTime?
}

model UserInterest {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  tag    String

  @@unique([userId, tag])
}

// LOGROS / ACHIEVEMENTS

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  unlockedAt    DateTime @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

// POLLA MUNDIALISTA 2026

enum PoolStatus {
  DRAFT
  OPEN_REGISTRATION
  LOCKED
  RESOLVED
}

enum PoolEntryStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum PoolQuestionType {
  TEAM_PICK
  PLAYER_PICK
  YES_NO
  SINGLE_CHOICE
  NUMERIC
  GROUP_RANK
}

enum PoolQuestionCategory {
  GLOBAL
  COLOMBIA
  BRACKET
}

model WorldCupPool {
  id                    String     @id @default(cuid())
  name                  String
  season                String     @default("2026")
  entryFee              Int
  prizeSplit            Json       @default("[60, 30, 10]")
  status                PoolStatus @default(DRAFT)
  lockAt                DateTime?
  nequiNumber           String?
  whatsappUrl           String?
  // Valores reales (los ingresa el admin al resolver, para los desempates por cercanía)
  colombiaGoalsReal     Int?
  totalGoalsReal        Int?
  // Puntos por pronóstico de marcador: resultado (1X2) + bono por marcador exacto
  matchPointsOutcome    Int        @default(3)
  matchPointsExactBonus Int        @default(2)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  questions PoolQuestion[]
  entries   PoolEntry[]
  matches   PoolMatch[]
}

model PoolQuestion {
  id            String               @id @default(cuid())
  poolId        String
  pool          WorldCupPool         @relation(fields: [poolId], references: [id], onDelete: Cascade)
  order         Int
  text          String
  type          PoolQuestionType
  category      PoolQuestionCategory @default(GLOBAL)
  options       Json                 @default("[]")
  correctAnswer Json?
  pointsValue   Int                  @default(20)
  isTiebreaker  Boolean              @default(false)
  tiebreakRank  Int?
  createdAt     DateTime             @default(now())

  answers PoolAnswer[]

  @@index([poolId])
}

model PoolEntry {
  id                 String          @id @default(cuid())
  poolId             String
  pool               WorldCupPool    @relation(fields: [poolId], references: [id], onDelete: Cascade)
  userId             String
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  status             PoolEntryStatus @default(PENDING)
  paymentNote        String?
  confirmedById      String?
  confirmedAt        DateTime?
  submittedAt        DateTime?
  totalPoints        Int             @default(0)
  groupsCorrect      Int             @default(0)
  colombiaGoalsGuess Int?
  totalGoalsGuess    Int?
  firstScorerCorrect Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  answers          PoolAnswer[]
  matchPredictions PoolMatchPrediction[]

  @@unique([poolId, userId])
  @@index([poolId, status])
}

model PoolAnswer {
  id           String       @id @default(cuid())
  entryId      String
  entry        PoolEntry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  questionId   String
  question     PoolQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer       Json
  isCorrect    Boolean?
  pointsEarned Int          @default(0)

  @@unique([entryId, questionId])
  @@index([questionId])
}

enum PoolMatchStatus {
  SCHEDULED // creado, aún no visible para pronosticar
  OPEN // abierto: los usuarios pueden pronosticar marcador
  CLOSED // cerrado: ya no se puede editar, sin resultado aún
  FINISHED // con resultado real cargado y puntos asignados
}

model PoolMatch {
  id        String          @id @default(cuid())
  poolId    String
  pool      WorldCupPool    @relation(fields: [poolId], references: [id], onDelete: Cascade)
  homeTeam  String
  awayTeam  String
  homeFlag  String?
  awayFlag  String?
  phase     String          @default("Fase de grupos")
  kickoffAt DateTime?
  order     Int             @default(0)
  status    PoolMatchStatus @default(SCHEDULED)
  homeScore Int?
  awayScore Int?
  createdAt DateTime        @default(now())

  predictions PoolMatchPrediction[]

  @@index([poolId])
}

model PoolMatchPrediction {
  id             String    @id @default(cuid())
  entryId        String
  entry          PoolEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  matchId        String
  match          PoolMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homePredict    Int
  awayPredict    Int
  outcomeCorrect Boolean?
  exactCorrect   Boolean?
  pointsEarned   Int       @default(0)
  updatedAt      DateTime  @updatedAt

  @@unique([entryId, matchId])
  @@index([matchId])
}
