# ══════════════════════════════════════════════════════════════
# LA TRIBUNA — Variables de entorno
# Copia este archivo a .env.local y completa los valores
# ══════════════════════════════════════════════════════════════

# ── Database (Neon PostgreSQL) ──
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# ── Auth (NextAuth v5) ──
NEXTAUTH_SECRET="genera-un-string-aleatorio-seguro"
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth ──
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Apple OAuth ──
APPLE_ID=""
APPLE_CLIENT_SECRET=""

# ── API-Football (api-sports.io) ──
API_FOOTBALL_KEY=""

# ── Upstash Redis ──
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Web Push (VAPID) ──
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="push@latribuna.co"

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Wompi (Pagos Colombia) ──
WOMPI_ENVIRONMENT="sandbox"
WOMPI_PUBLIC_KEY=""
WOMPI_PRIVATE_KEY=""
WOMPI_EVENTS_SECRET=""
WOMPI_INTEGRITY_SECRET=""

# ── Cron Jobs ──
CRON_SECRET="genera-un-string-aleatorio-para-crons"

# ── Socket Server (Railway) ──
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"

# ── Firebase Admin (opcional, para FCM legacy) ──
# FIREBASE_PROJECT_ID=""
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY=""

# ── App URL (para links compartidos) ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
